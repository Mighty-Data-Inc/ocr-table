{
  "name": "@mightydatainc/ocr-table",
  "version": "1.0.0",
  "description": "Extract structured table data from PDFs, PNGs, etc., using LLM vision models",
  "author": "Mikhail Voloshin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mighty-Data-Inc/ocr-table"
  },
  "type": "module",
  "sideEffects": false,
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "llm",
    "openai",
    "responses-api",
    "structured-outputs",
    "chat"
  ],
  "dependencies": {
    "@mightydatainc/gpt-conversation": "^2.0.0",
    "dotenv": "^17.3.1",
    "openai": "^6.2.0",
    "pdf-to-png-converter": "^3.14.0"
  },
  "devDependencies": {
    "@types/node": "^22.18.10",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
